{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "outDir": "dist",

    "rootDir": "src",

    "baseUrl": "src",

    "paths": {
      "@/*": ["*"],

      "@/modules/*": ["modules/*"],

      "@/infrastructure/*": ["infrastructure/*"],

      "@/shared/*": ["shared/*"],

      "@/config/*": ["config/*"],

      "@/bootstrap/*": ["bootstrap/*"]
    },

    "types": ["node"]
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}
