{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",

    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "strict": true,

    "experimentalDecorators": true,

    "emitDecoratorMetadata": true,

    "useDefineForClassFields": false,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "sourceMap": true,

    "incremental": true,

    "composite": true
  }
}